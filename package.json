    "test": "pnpm -r test",
    "tauri": "pnpm --filter @pixi-board/desktop tauri"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.25.0"
}
