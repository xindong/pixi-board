{
  "name": "pixi-board",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @pixi-board/desktop dev",
    "dev:mcp": "pnpm --filter @pixi-board/mcp dev",
