{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@pixi-board/board-plugin-sdk": ["../../packages/board-plugin-sdk/src/index.ts"],
      "@pixi-board/board-tool-runtime": ["../../packages/board-tool-runtime/src/index.ts"],
      "@pixi-board/mcp-protocol": ["../../packages/board-mcp-protocol/src/index.ts"]
    },
    "noEmit": true
  },
  "include": ["src"]
}
