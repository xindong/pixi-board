  },
  "dependencies": {
    "@pixi-board/board-plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
